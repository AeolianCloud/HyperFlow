# PVE 虚拟化底座连接配置
# PVE 服务器地址（含端口）
PVE_HOST=https://192.168.1.100:8006

# PVE API Token 认证（格式: user@realm!tokenid）
PVE_TOKEN_ID=root@pam!mytoken

# PVE API Token Secret
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 是否跳过 SSL 证书校验（开发环境使用，生产环境请勿开启）
PVE_INSECURE=false

# ciPackages 功能所需：WebDAV 上传地址，指向 PVE snippets 存储对应的 WebDAV 目录根路径
# 示例：PVE_SNIPPETS_WEBDAV_URL=http://192.168.1.100/dav/snippets
PVE_SNIPPETS_WEBDAV_URL=

# WebDAV 认证（可选）
PVE_SNIPPETS_WEBDAV_USER=
PVE_SNIPPETS_WEBDAV_PASSWORD=

# MySQL 连接配置（用于持久化异步操作记录，重启后仍可查询）
# 应用会强制将 MySQL 会话时间和解析时区固定为上海时区，因此这里无需额外手动设置 loc / time_zone。
# 格式：user:password@tcp(host:port)/dbname?timeout=5s&readTimeout=30s&writeTimeout=10s
MYSQL_DSN=root:secret@tcp(127.0.0.1:3306)/hyperflow?parseTime=true&timeout=5s&readTimeout=30s&writeTimeout=10s

# Kafka 配置（用于发布 operation 终态事件，供门户后端订阅）
# 多个 broker 以逗号分隔
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_OPERATION_EVENTS_TOPIC=hyperflow.operation-events
