# PVE 虚拟化底座连接配置
# PVE 服务器地址（含端口）
PVE_HOST=https://192.168.1.100:8006

# PVE API Token 认证（格式: user@realm!tokenid）
PVE_TOKEN_ID=root@pam!mytoken

# PVE API Token Secret
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 是否跳过 SSL 证书校验（开发环境使用，生产环境请勿开启）
PVE_INSECURE=false

# ciPackages 功能所需：WebDAV 上传地址，指向 PVE snippets 存储对应的 WebDAV 目录根路径
# 示例：PVE_SNIPPETS_WEBDAV_URL=http://192.168.1.100/dav/snippets
PVE_SNIPPETS_WEBDAV_URL=

# WebDAV 认证（可选）
PVE_SNIPPETS_WEBDAV_USER=
PVE_SNIPPETS_WEBDAV_PASSWORD=
